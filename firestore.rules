rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function ehDono(userId) {
      return estaLogado() && request.auth.uid == userId;
    }

    function ehAdmin() {
      return estaLogado() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cargo == 'admin';
    }

    function tipoDePostagemValido(tipo) {
      return tipo in ['avisoTexto', 'aoVivo', 'avisoFoto', 'enquete'];
    }

    // Vota numa enquete: qualquer usuario logado pode, uma unica vez por post,
    // e a escrita so pode alterar 'opcoes' e 'votantes' (nada mais do post).
    function podeVotar() {
      return estaLogado()
        && resource.data.tipo == 'enquete'
        && !(request.auth.uid in resource.data.get('votantes', []))
        && request.resource.data.votantes == resource.data.get('votantes', []).concat([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['opcoes', 'votantes']);
    }

    function categoriasValidas(categorias) {
      return categorias is list &&
        categorias.hasOnly(['otaku', 'gamer', 'streamer', 'geek', 'outro']);
    }

    function statusValido(status) {
      return status in ['online', 'invisivel', 'naoPerturbe', 'offline'];
    }

    match /users/{userId} {
      allow read: if estaLogado();

      // cargo pode ser 'inscrito', 'vip' ou 'admin'. 'vip' e 'admin' sao
      // atribuidos manualmente (nunca no cadastro), por isso o create abaixo
      // so aceita 'inscrito', e o update trava o cargo contra mudanca pelo cliente.
      allow create: if ehDono(userId)
        && request.resource.data.cargo == 'inscrito'
        && request.resource.data.badges.size() == 0
        && request.resource.data.contadores.comentarios == 0
        && request.resource.data.contadores.curtidas == 0
        && request.resource.data.contadores.cliquesLive == 0
        && categoriasValidas(request.resource.data.categorias)
        && statusValido(request.resource.data.status)
        && request.resource.data.ultimoAcesso == request.time;

      allow update: if ehDono(userId)
        && request.resource.data.cargo == resource.data.cargo
        && request.resource.data.badges == resource.data.badges
        && request.resource.data.contadores == resource.data.contadores
        && categoriasValidas(request.resource.data.categorias)
        && statusValido(request.resource.data.status)
        && request.resource.data.ultimoAcesso == request.time;

      allow delete: if ehDono(userId);
    }

    // Mapeia nickname (em minusculo) -> email/uid, pra permitir login com
    // nickname sem precisar de leitura autenticada na colecao users (o
    // usuario ainda nao esta logado nesse momento). So expoe email, nada
    // do resto do perfil. So o dono do uid pode criar/atualizar a propria
    // entrada, e o id do documento (nickname) impede duas contas com o
    // mesmo nickname (a segunda tentativa vira "update" de um dono diferente
    // e e barrada).
    match /nicknamesParaEmail/{nicknameChave} {
      allow read: if true;
      allow create: if estaLogado() && request.auth.uid == request.resource.data.uid;
      allow update: if estaLogado()
        && request.auth.uid == resource.data.uid
        && request.auth.uid == request.resource.data.uid;
      allow delete: if false;
    }

    // Feed de avisos do canal (Home). O painel de admin dentro do app ainda
    // nao existe, entao por enquanto os posts sao criados manualmente pelo
    // admin direto no Console do Firebase (o que ja tem acesso irrestrito e
    // ignora essas regras) — essa regra aqui serve pra quando o painel for
    // construido, e pra impedir qualquer outro usuario de escrever posts.
    match /posts/{postId} {
      allow read: if estaLogado();
      allow create, update: if ehAdmin() && tipoDePostagemValido(request.resource.data.tipo);
      allow update: if podeVotar();
      allow delete: if ehAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
